# --- Postgres ---
POSTGRES_USER=finos
POSTGRES_PASSWORD=finos_dev_password
POSTGRES_DB=finos
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://finos:finos_dev_password@postgres:5432/finos

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- JWT ---
JWT_SECRET=change-me-to-a-long-random-string-in-every-environment
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=14
# Signs the transient OAuth "state" cookie -- must differ from JWT_SECRET in
# production (Settings rejects a production boot where they're equal, or
# where either is left at its .env.example placeholder / under 32 chars).
# Safe to leave blank in dev -- falls back to JWT_SECRET.
SESSION_SECRET=change-me-to-a-different-long-random-string-in-every-environment
# Field-level encryption key for connector_credential/oauth_accounts token
# columns (Milestone 8). This is a real, well-formed Fernet key but it's
# PUBLIC (checked into this example file) -- Settings rejects it in
# production. Generate your own with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=VMLWJOtffXQuSHEHlgUY9mc_2Tpuzg_zr1yzKjqtImY=

# --- OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_REDIRECT_BASE_URL=http://localhost:8000
WEB_BASE_URL=http://localhost:3000

# --- App ---
ENVIRONMENT=development
CORS_ALLOW_ORIGINS=http://localhost:3000

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- AI (Milestone 4) ---
ANTHROPIC_API_KEY=

# --- Plaid (Milestone 9) ---
# Free sandbox signup, no business verification required:
#   1. dashboard.plaid.com/signup
#   2. Team Settings -> Keys -> copy `client_id` + the `sandbox` secret
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
